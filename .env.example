# SMS.ir settings
SMS_IR_API_KEY=your_sms_ir_api_key
SMS_IR_LINE_NUMBER=3000XXXXXXXXXX
SMS_IR_BASE_URL=https://api.sms.ir

# Keep true for testing. Set to false only when real SMS sending is approved.
SMS_DRY_RUN=true

# Optional: simple password for API calls from the browser.
# If you set it here, also set it inside the panel Settings page.
HR_PANEL_API_TOKEN=
